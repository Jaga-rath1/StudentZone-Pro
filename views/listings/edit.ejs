<% layout("/layouts/boilerplate") %>
<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow rounded-4">

                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Edit Student</h2>
                        <p class="text-muted">
                            Update details for <strong><%= s1.name %></strong>
                        </p>
                    </div>

                    <form
                        action="/users/<%= s1._id %>?_method=PATCH"
                        method="POST"
                        class="needs-validation"
                        novalidate
                    >

                        <div class="mb-3">
                            <label class="form-label">Age</label>
                            <input
                                type="number"
                                name="age"
                                value="<%= s1.age %>"
                                class="form-control"
                                min="1"
                                required
                            >
                            <div class="invalid-feedback">
                                Please enter a valid age.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Course</label>
                            <input
                                type="text"
                                name="course"
                                value="<%= s1.course %>"
                                class="form-control"
                                required
                            >
                            <div class="invalid-feedback">
                                Please enter course name.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Total Fees</label>
                            <input
                                type="number"
                                name="totalfees"
                                value="<%= s1.totalfees %>"
                                class="form-control"
                                min="0"
                                required
                            >
                            <div class="invalid-feedback">
                                Please enter total fees.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fees Paid</label>
                            <input
                                type="number"
                                name="feespaid"
                                value="<%= s1.feespaid %>"
                                class="form-control"
                                min="0"
                                required
                            >
                            <div class="invalid-feedback">
                                Please enter fees paid.
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Remaining Fees</label>
                            <input
                                type="number"
                                name="remainingfees"
                                value="<%= s1.remainingfees %>"
                                class="form-control"
                                min="0"
                                required
                            >
                            <div class="invalid-feedback">
                                Please enter remaining fees.
                            </div>
                        </div>

                        <div class="d-flex gap-2">

                            <button class="btn btn-warning flex-grow-1">
                                Update Student
                            </button>

                            <a
                                href="/users/<%= s1._id %>"
                                class="btn btn-outline-secondary"
                            >
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>