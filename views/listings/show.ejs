<% layout("/layouts/boilerplate") %>
<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow rounded-4">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center"
                             style="width:90px;height:90px;font-size:2rem;">
                            <%= s1.name.charAt(0).toUpperCase() %>
                        </div>

                        <h2 class="fw-bold mt-3">
                            <%= s1.name %>
                        </h2>

                        <p class="text-muted">
                            Student Details
                        </p>

                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <strong>User ID</strong><br>
                                <small><%= s1._id %></small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <strong>Age</strong><br>
                                <%= s1.age %>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <strong>Course</strong><br>
                                <%= s1.course %>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <strong>Total Fees</strong><br>
                                ₹<%= s1.totalfees %>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <strong>Fees Paid</strong><br>
                                ₹<%= s1.feespaid %>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <strong>Remaining Fees</strong><br>
                                ₹<%= s1.remainingfees %>
                            </div>
                        </div>

                    </div>

                    <div class="d-flex gap-3 mt-5">

                        <a href="/users/<%= s1._id %>/edit"
                           class="btn btn-warning flex-fill">
                            Edit Student
                        </a>

                        <form
                            action="/users/<%= s1._id %>?_method=DELETE"
                            method="POST"
                            class="flex-fill"
                        >
                            <button class="btn btn-danger w-100">
                                Delete Student
                            </button>
                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>